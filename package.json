{
  "name": "ai-browser-bridge",
  "version": "0.1.0",
  "description": "Drives ChatGPT or Gemini in Chrome from the terminal; ChatGPT can use sandboxed local repo tools via MCP.",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "bin": {
    "bridge": "./dist/bridge.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "husky",
    "prepack": "npm run build",
    "prestart": "npm run build",
    "start": "node dist/bridge.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:class-api": "node scripts/check-class-api.mjs",
    "check:jsdoc": "node scripts/check-jsdoc.mjs",
    "verify:push": "npm run typecheck && npm test && npm run build && npm run check:class-api && npm run check:jsdoc"
  },
  "keywords": [
    "chatgpt",
    "mcp",
    "cli",
    "browser-automation",
    "playwright",
    "ink",
    "cloudflare-tunnel",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.3",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.4.2",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.12",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2"
  }
}
