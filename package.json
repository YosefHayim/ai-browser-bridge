{
  "name": "ai-browser-bridge",
  "version": "0.1.0",
  "description": "Drive ChatGPT, Gemini, Claude, DeepSeek, Grok, or Perplexity in Chrome from the terminal — one provider or fan out across several — for humans and agents. ChatGPT can use sandboxed local repo tools via MCP.",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bridge": "./dist/bridge.js"
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YosefHayim/ai-browser-bridge.git"
  },
  "homepage": "https://github.com/YosefHayim/ai-browser-bridge#readme",
  "bugs": {
    "url": "https://github.com/YosefHayim/ai-browser-bridge/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "husky",
    "prepack": "npm run build",
    "prestart": "npm run build",
    "start": "node dist/bridge.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./",
    "format:check": "biome format ./",
    "lint": "biome lint ./",
    "lint:fix": "biome check --write ./",
    "check:ci": "biome ci ./",
    "check:class-api": "node src/scripts/dev/checkClassApi.mjs",
    "check:tsdoc": "node src/scripts/dev/checkTsdoc.mjs",
    "check:boundaries": "node src/scripts/dev/checkBoundaries.mjs",
    "check:no-deprecated": "node src/scripts/dev/checkNoDeprecated.mjs",
    "verify": "pnpm run check:ci && pnpm run typecheck && pnpm test && pnpm run build && pnpm run check:class-api && pnpm run check:tsdoc && pnpm run check:boundaries && pnpm run check:no-deprecated",
    "verify:push": "pnpm run verify"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "keywords": [
    "chatgpt",
    "mcp",
    "cli",
    "browser-automation",
    "playwright",
    "ink",
    "cloudflare-tunnel",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^15.0.0",
    "effect": "^3.21.4",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@effect/vitest": "^0.29.0",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.12",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2"
  }
}
